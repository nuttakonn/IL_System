pipeline {
    agent { label "hwcnp-jenkins-uat" } 
    environment{ 
        nexusURL="172.22.193.207:8123"
        nexusURLPRD="172.29.65.251:8123"
        deployServer="172.29.65.195"

        appName="ilscreen-ui"
        appPath="ILSCREEN_UI"
		appPort="5000"
        service="frontend"
        product="ilscreen_system"
		
        replicaset="3"
        cpu="50m"
		memory="400Mi"
        nameSpace="internalapp-out-02"
		host="ilscreen.siamac.com"
    }
    
    stages {
        stage ('Initialize') {
            agent { 
                label "hwcnp-jenkins-uat" 
            }
            steps {
                sh "hostname"
                sh "kubectl get nodes"
                sh "docker ps"
                sh '''
                    echo "PATH = ${PATH}"
                    cd src/${appPath}
                    echo ${appName}
                '''
            }
        }
		
		stage ('Enter Move Version') {
            agent {
                label "hwcnp-jenkins-uat"
            }
            steps {
                timeout(15){
                    script {
                        env.RELEASE_VERSION = input message: 'Enter Move Version', ok: 'Proceed', parameters: [string(defaultValue: '', description: '', name: 'Version')]
                    }
                }
                echo "${env.RELEASE_VERSION}"
            }
        }
		
		stage ('Confirm Move Version') {
            steps {
                timeout(15){
                    input "Confirm Move Version : ${env.RELEASE_VERSION}"
                }
            }
        }

        stage ('Upload Nexus Production') {
            agent { 
                label "hwcnp-jenkins-uat" 
            }
            steps {
                sh '''
                    hostname
                    echo 'Promote to Production'
                    cd src/${appPath}
                    docker pull ${nexusURL}/${appName}:${RELEASE_VERSION}
                    docker tag ${nexusURL}/${appName}:${RELEASE_VERSION} ${nexusURLPRD}/${appName}:${RELEASE_VERSION}
                    docker push ${nexusURLPRD}/${appName}:${RELEASE_VERSION}
                    docker image remove ${nexusURL}/${appName}:${RELEASE_VERSION}
                    docker image remove ${nexusURLPRD}/${appName}:${RELEASE_VERSION}
                '''
            }
        }
		
		stage ('Deploy Production') {
            agent { 
                label "hwcnp-jenkins-uat" 
            }
            environment {
                dockerurl="${nexusURLPRD}"
                replicaset="${replicaset}"
                aspnetcoreenvironment="Production"
            }
            steps {
                sh '''
                    cd src/${appPath}
                    cp deployment.yaml deployment-${appName}-PRD.yaml
                    sed -i s/#PRODUCT#/${product}/g deployment-${appName}-PRD.yaml
					sed -i s/#SERVICETYPE#/${service}/g deployment-${appName}-PRD.yaml
                    sed -i s/#APP_NAME#/${appName}/g deployment-${appName}-PRD.yaml
                    sed -i s/#APP_VERSION#/${RELEASE_VERSION}/g deployment-${appName}-PRD.yaml
                    sed -i s/#NAMESPACE#/${nameSpace}/g deployment-${appName}-PRD.yaml
                    sed -i s/#DOCKERURL#/${dockerurl}/g deployment-${appName}-PRD.yaml
                    sed -i s/#REPLICASET#/${replicaset}/g deployment-${appName}-PRD.yaml
                    sed -i s/#ASPNETCORE_ENVIRONMENT#/${aspnetcoreenvironment}/g deployment-${appName}-PRD.yaml
					sed -i s/#MEMORY#/${memory}/g deployment-${appName}-PRD.yaml
					sed -i s/#CPU#/${cpu}/g deployment-${appName}-PRD.yaml
					sed -i s/#PORT#/${appPort}/g deployment-${appName}-PRD.yaml
                    sed -i s/#DOCKERNAMESPACE#/${nameSpace}/g deployment-${appName}-PRD.yaml
                    sed -i s/#TIER#/${service}/g deployment-${appName}-PRD.yaml
					
                    cat deployment-${appName}-PRD.yaml
                    ssh jenkins@${deployServer} "kubectl get nodes"
                    scp deployment-${appName}-PRD.yaml jenkins@${deployServer}:deployment-${appName}-PRD.yaml
                    ssh jenkins@${deployServer} "kubectl apply -f deployment-${appName}-PRD.yaml"
                '''
            }
        }
		
		stage ('Deploy Success') {
            agent { 
                label "hwcnp-jenkins-uat" 
            }
            steps {
                sh '''
                    echo ${RELEASE_VERSION}
                '''
            }
        }
    }
}