<script>
    function initial(){

        let tbData_CustomerInquiry = $('#tb_CustomerInquiry');
        let tbData_DescriptionTermAndRate = $('#tb_DescriptionTermAndRate');
        let tbData_DescriptionInstallment = $('#tb_DescriptionInstallment');

        tbData_CustomerInquiry.DataTable({
            "lengthChange": true,
            responsive: true,
            "pageLength": 20,
            scrollX: true,
            columns: [
                {
                    title: 'Select',
                    width: '10%',
                    targets: 0,
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                    render: (data, type, row, meta) => {
                        // return meta.row + 1;
                        return '<a href=' + meta.row + '>Select<a/>';
                    }
                },
                {
                    type: 'string',
                    data: 'idNo',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'name',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'csn',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'applicationDate',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'applicationType',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'applicationNo',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'branch',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'contractNo',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
            ]
        });

        tbData_DescriptionTermAndRate.DataTable({
            "lengthChange": true,
            responsive: true,
            "pageLength": 20,
            scrollX: true,
            columns: [
                {
                    type: 'string',
                    data: 'fromTerm',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'toTerm',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'int',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'intEirYear',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'cru',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'cruEirYear',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'initFree',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'totalAmount',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'oth',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'install',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'creditBureau',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                }
            ]
        });

        tbData_DescriptionInstallment.DataTable({
            "lengthChange": true,
            responsive: true,
            "pageLength": 20,
            scrollX: true,
            columns: [
                {
                    type: 'string',
                    data: 'term',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'name',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'principal',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
