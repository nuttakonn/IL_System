                {
                    type: 'string',
                    data: 'interest',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'crUsage',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'initFee',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'payPrincipal',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'newPrincipal',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'income',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'closingDate',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'closingRebate',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
                {
                    type: 'string',
                    data: 'amount',
                    orderable: true,
                    searchable: false,
                    className: 'dt-body-center dt-head-center',
                },
            ]
        });
    }

    $(document).ready(function () {
        initial();
    });
</script>
